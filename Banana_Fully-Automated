    while True:
        # Standard speed for Reset
        travel(card, pipeline, align_obj, ZONE_START, 5.0, "RESET", current_grip=0.0)
        
        locked_on = False
        for pose, name in PATROL_SEQUENCE:
            if locked_on: break
            travel(card, pipeline, align_obj, pose, 6.0, f"SCANNING {name}", current_grip=0.0)
            
            scan_t = time.time()
