                    if res[0].masks is not None and len(res[0].masks.data) > 0:
                        if run_precision_alignment(card, pipeline, align_obj, model):
                            locked_on = True; break
                        else: break
                    cv2.imshow("Q-Arm Mission Control", img)
                if cv2.waitKey(1) & 0xFF == ord('q'): sys.exit()
        
        if locked_on: 
            # 1. PICK (Slow Grip)
            print("✊ GRIPPING SLOWLY (Target: 0.75)...")
            state = array('d', [0.0]*5); card.read_other(CHANNELS, 5, state); q_curr = list(state)
            
            target_force = 0.85
            grip_steps = 5
            for s in range(grip_steps + 1):
                q_curr[4] = (target_force / grip_steps) * s
                card.write_other(CHANNELS, 5, array('d', q_curr))
                time.sleep(0.1) # Total grip time: ~2.0 seconds
            
            time.sleep(1.0) 

            # 2. TRANSIT - EXTRA SLOW (Durations increased to 12.0s)
            travel(card, pipeline, align_obj, ZONE_WAYPOINT_1, 12.0, "TRANSIT 1 (EXTRA SLOW)", current_grip=0.85)
            travel(card, pipeline, align_obj, ZONE_WAYPOINT_2, 12.0, "TRANSIT 2 (EXTRA SLOW)", current_grip=0.85)
            travel(card, pipeline, align_obj, ZONE_WAYPOINT_3, 12.0, "TRANSIT 3 (EXTRA SLOW)", current_grip=0.85)

            # 3. PLACE - EXTRA SLOW (Duration increased to 15.0s)
            travel(card, pipeline, align_obj, ZONE_PLACE, 15.0, "DROP-OFF (EXTRA SLOW)", current_grip=0.85)
            
            release_pose = list(ZONE_PLACE); release_pose[4] = 0.0 
            card.write_other(CHANNELS, 5, array('d', release_pose)); time.sleep(2.0)

finally:
    card.close(); pipeline.stop(); cv2.destroyAllWindows()
